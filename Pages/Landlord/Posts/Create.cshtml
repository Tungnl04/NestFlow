@page
@model NestFlow.Pages.Landlord.Posts.CreateModel
@{
    ViewData["Title"] = "Đăng tin mới (All-in-one)";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Header Section -->
            <div class="mb-4 d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold text-primary mb-1">Tạo bài đăng mới</h2>
                    <p class="text-muted">Nhập thông tin phòng trọ và nội dung quảng cáo để bắt đầu tìm khách thuê.</p>
                </div>
                <a asp-page="./Index" class="btn btn-outline-secondary px-4">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>

            <form method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="text-danger mb-4"></div>

                <!-- Section 1: Nội dung bài đăng (Quảng cáo) -->
                <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="mb-0"><i class="fas fa-bullhorn me-2"></i>1. Nội dung tin đăng</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label asp-for="NewListing.Title" class="form-label fw-semibold">Tiêu đề bài đăng <span class="text-danger">*</span></label>
                            <input asp-for="NewListing.Title" class="form-control form-control-lg border-2" placeholder="Ví dụ: Phòng trọ cao cấp trung tâm Quận 1 - Đầy đủ tiện nghi" required />
                            <div class="form-text">Tiêu đề hấp dẫn giúp tăng 50% lượt click của người thuê.</div>
                        </div>

                        <div class="mb-0">
                            <label asp-for="NewListing.Content" class="form-label fw-semibold">Nội dung chi tiết</label>
                            <textarea asp-for="NewListing.Content" class="form-control border-2" rows="6" placeholder="Mô tả các ưu điểm về vị trí, giao thông, an ninh, giờ giấc..."></textarea>
                        </div>
                    </div>
                </div>

                <!-- Section 2: Thông tin chi tiết Phòng trọ -->
                <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                    <div class="card-header bg-success text-white py-3">
                        <h5 class="mb-0"><i class="fas fa-home me-2"></i>2. Đặc điểm Phòng trọ</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-4">
                            <div class="col-md-4">
                                <label asp-for="NewProperty.PropertyType" class="form-label fw-semibold">Loại hình</label>
                                <select asp-for="NewProperty.PropertyType" class="form-select border-2" required>
                                    <option value="phong_tro">Phòng trọ</option>
                                    <option value="chung_cu">Chung cư mini</option>
                                    <option value="nha_nguyen_can">Nhà nguyên căn</option>
                                    <option value="studio">Studio / Căn hộ dịch vụ</option>
                                    <option value="o_ghep">Ở ghép</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="NewProperty.Price" class="form-label fw-semibold">Giá thuê (VND/tháng) <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <input asp-for="NewProperty.Price" type="number" class="form-control border-2" required min="100000" />
                                    <span class="input-group-text">VND</span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="NewProperty.Deposit" class="form-label fw-semibold">Tiền đặt cọc (VND)</label>
                                <div class="input-group">
                                    <input asp-for="NewProperty.Deposit" type="number" class="form-control border-2" min="0" />
                                    <span class="input-group-text">VND</span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="NewProperty.Area" class="form-label fw-semibold">Diện tích (m²)</label>
                                <div class="input-group">
                                    <input asp-for="NewProperty.Area" type="number" class="form-control border-2" step="any" />
                                    <span class="input-group-text">m²</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="NewProperty.MaxOccupants" class="form-label fw-semibold">Số người tối đa</label>
                                <input asp-for="NewProperty.MaxOccupants" type="number" class="form-control border-2" min="1" />
                            </div>

                            <div class="col-12 mt-4">
                                <label class="form-label fw-bold text-secondary text-uppercase small">Vị trí & Địa chỉ</label>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <input asp-for="NewProperty.City" class="form-control border-2" placeholder="Tỉnh / Thành phố" />
                                    </div>
                                    <div class="col-md-4">
                                        <input asp-for="NewProperty.District" class="form-control border-2" placeholder="Quận / Huyện" />
                                    </div>
                                    <div class="col-md-4">
                                        <input asp-for="NewProperty.Ward" class="form-control border-2" placeholder="Phường / Xã" />
                                    </div>
                                    <div class="col-12">
                                        <input asp-for="NewProperty.Address" class="form-control border-2" placeholder="Số nhà, tên đường, hẻm..." required />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Section 3: Tiện nghi & Dịch vụ -->
                <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                    <div class="card-header bg-info text-white py-3">
                        <h5 class="mb-0"><i class="fas fa-concierge-bell me-2"></i>3. Tiện nghi & Dịch vụ</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row">
                            @{
                                var categories = Model.AvailableAmenities.Select(a => a.Category).Distinct().ToList();
                                foreach (var cat in categories)
                                {
                                    <div class="col-md-4 mb-4">
                                        <h6 class="fw-bold text-uppercase text-secondary mb-3 small">
                                            @if(cat == "basic") { <text>Cơ bản</text> }
                                            else if(cat == "furniture") { <text>Nội thất</text> }
                                            else if(cat == "security") { <text>An ninh</text> }
                                            else { @cat }
                                        </h6>
                                        <div class="d-flex flex-column gap-2">
                                            @foreach (var amenity in Model.AvailableAmenities.Where(a => a.Category == cat))
                                            {
                                                <div class="form-check custom-checkbox">
                                                    <input class="form-check-input" type="checkbox" name="SelectedAmenityIds" 
                                                           value="@amenity.AmenityId" id="amenity_@amenity.AmenityId"
                                                           @(Model.SelectedAmenityIds.Contains(amenity.AmenityId) ? "checked" : "")>
                                                    <label class="form-check-label" for="amenity_@amenity.AmenityId">
                                                        @if(!string.IsNullOrEmpty(amenity.IconUrl)) { <i class="@amenity.IconUrl me-1"></i> }
                                                        @amenity.Name
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>

                <!-- Section 4: Hình ảnh & Media 360 -->
                <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                    <div class="card-header bg-dark text-white py-3">
                        <h5 class="mb-0"><i class="fas fa-images me-2"></i>4. Hình ảnh & Media 360</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-4">
                            <!-- Ảnh thường -->
                            <div class="col-md-6 border-end">
                                <label class="form-label fw-bold"><i class="fas fa-camera me-1"></i> Ảnh thực tế (Thường)</label>
                                <label class="btn btn-outline-secondary w-100 py-4 border-dashed mb-2" style="border: 2px dashed #ccc;">
                                    <i class="fas fa-upload d-block mb-2"></i>
                                    <span>Chọn ảnh thường</span>
                                    <input type="file" asp-for="UploadedImages" multiple accept="image/*" class="d-none" id="imgInput" />
                                </label>
                                <div id="imagePreview" class="row g-2 mt-2" style="max-height: 150px; overflow-y: auto;"></div>
                                <small class="text-muted d-block mt-1">Nên có ít nhất 3 ảnh: Mặt tiền, Phòng khách, WC.</small>
                            </div>

                            <!-- Ảnh 360 -->
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-info"><i class="fas fa-street-view me-1"></i> Ảnh Panorama 360°</label>
                                <label class="btn btn-outline-info w-100 py-4 border-dashed mb-2" style="border: 2px dashed #0dcaf0;">
                                    <i class="fas fa-vr-cardboard d-block mb-2 text-info"></i>
                                    <span>Chọn ảnh 360°</span>
                                    <input type="file" asp-for="Uploaded360Images" accept="image/*" class="d-none" id="img360Input" />
                                </label>
                                <div id="image360Preview" class="row g-2 mt-2" style="max-height: 150px; overflow-y: auto;"></div>
                                <small class="text-info d-block mt-1">Ảnh sẽ được lưu với hậu tố <code>_360</code> để kích hoạt trình xem thực tế ảo.</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sticky Action Bar -->
                <div class="card shadow-lg border-0 bg-light sticky-bottom mt-5">
                    <div class="card-body p-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <div class="me-3">
                                <label asp-for="NewListing.Status" class="form-label mb-0 fw-bold me-2">Hành động:</label>
                                <select asp-for="NewListing.Status" class="form-select d-inline-block w-auto">
                                    <option value="active">Đăng tin ngay</option>
                                    <option value="draft">Lưu bản nháp</option>
                                </select>
                            </div>
                            <span class="badge bg-warning text-dark"><i class="fas fa-gem me-1"></i> Sẽ áp dụng VIP theo gói của bạn</span>
                        </div>
                        <div class="gap-2 d-flex">
                            <button type="submit" class="btn btn-primary btn-lg px-5 shadow">
                                <i class="fas fa-check-circle me-2"></i>Xác nhận Đăng tin
                            </button>
                        </div>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Sử dụng DataTransfer để có thể xóa file trong input[type=file]
        let normalFiles = new DataTransfer();
        let files360 = new DataTransfer();

        const imgInput = document.getElementById('imgInput');
        const img360Input = document.getElementById('img360Input');

        function updatePreview(inputId, previewId, dt, is360) {
            const preview = document.getElementById(previewId);
            const input = document.getElementById(inputId);
            preview.innerHTML = '';
            
            Array.from(dt.files).forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = function(re) {
                    const col = document.createElement('div');
                    col.className = 'col-3 position-relative preview-item animate__animated animate__fadeIn';
                    let badge = is360 ? '<span class="badge bg-info position-absolute top-0 start-0 m-1" style="z-index:10">360°</span>' : '';
                    col.innerHTML = `
                        ${badge}
                        <img src="${re.target.result}" class="img-thumbnail" style="height: 100px; width: 100%; object-fit: cover;">
                        <button type="button" class="btn btn-danger btn-sm rounded-circle position-absolute top-0 end-0 m-1 shadow-sm" 
                                style="width:24px; height:24px; padding:0; display:flex; align-items:center; justify-content:center; z-index:11"
                                onclick="removeSelectedFile('${inputId}', '${previewId}', ${index}, ${is360})">
                            <i class="fas fa-times"></i>
                        </button>
                    `;
                    preview.appendChild(col);
                }
                reader.readAsDataURL(file);
            });
            // Đồng bộ lại file vào input thực tế
            input.files = dt.files;
        }

        function removeSelectedFile(inputId, previewId, index, is360) {
            let dt = is360 ? files360 : normalFiles;
            const newDt = new DataTransfer();
            Array.from(dt.files).forEach((file, i) => {
                if (i !== index) newDt.items.add(file);
            });
            
            if (is360) files360 = newDt; else normalFiles = newDt;
            updatePreview(inputId, previewId, is360 ? files360 : normalFiles, is360);
        }

        imgInput.addEventListener('change', function(e) {
            Array.from(e.target.files).forEach(file => normalFiles.items.add(file));
            updatePreview('imgInput', 'imagePreview', normalFiles, false);
        });

        img360Input.addEventListener('change', function(e) {
            files360 = new DataTransfer(); // Reset để chỉ lấy 1 ảnh mới nhất
            Array.from(e.target.files).forEach(file => files360.items.add(file));
            updatePreview('img360Input', 'image360Preview', files360, true);
        });
    </script>
}

<style>
    .border-dashed:hover {
        background: #f0f4ff !important;
        cursor: pointer;
    }
    .sticky-bottom {
        bottom: 1rem;
        z-index: 1020;
    }
</style>
