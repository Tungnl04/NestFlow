@page "{id:long}"
@model NestFlow.Pages.Landlord.Posts.EditModel
@{
    ViewData["Title"] = "Chỉnh sửa bài đăng (All-in-one)";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Header Section -->
            <div class="mb-4 d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold text-primary mb-1">Cập nhật bài đăng</h2>
                    <p class="text-muted">Chỉnh sửa nội dung tin đăng và thông tin phòng trọ của bạn.</p>
                </div>
                <a asp-page="./Index" class="btn btn-outline-secondary px-4">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>

            <form method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="text-danger mb-4"></div>
                <input type="hidden" asp-for="EditingListing.ListingId" />
                <input type="hidden" asp-for="EditingProperty.PropertyId" />

                <!-- Section 1: Nội dung bài đăng (Quảng cáo) -->
                <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="mb-0"><i class="fas fa-bullhorn me-2"></i>1. Nội dung tin đăng</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label asp-for="EditingListing.Title" class="form-label fw-semibold">Tiêu đề bài đăng <span class="text-danger">*</span></label>
                            <input asp-for="EditingListing.Title" class="form-control form-control-lg border-2" placeholder="Ví dụ: Phòng trọ cao cấp trung tâm Quận 1" required />
                        </div>

                        <div class="mb-0">
                            <label asp-for="EditingListing.Content" class="form-label fw-semibold">Nội dung chi tiết</label>
                            <textarea asp-for="EditingListing.Content" class="form-control border-2" rows="6"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Section 2: Thông tin chi tiết Phòng trọ -->
                <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                    <div class="card-header bg-success text-white py-3">
                        <h5 class="mb-0"><i class="fas fa-home me-2"></i>2. Đặc điểm Phòng trọ</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-4">
                            <div class="col-md-4">
                                <label asp-for="EditingProperty.PropertyType" class="form-label fw-semibold">Loại hình</label>
                                <select asp-for="EditingProperty.PropertyType" class="form-select border-2" required>
                                    <option value="phong_tro">Phòng trọ</option>
                                    <option value="chung_cu">Chung cư mini</option>
                                    <option value="nha_nguyen_can">Nhà nguyên căn</option>
                                    <option value="studio">Studio</option>
                                    <option value="o_ghep">Ở ghép</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="EditingProperty.Price" class="form-label fw-semibold">Giá thuê (VND/tháng) <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <input asp-for="EditingProperty.Price" type="number" class="form-control border-2" required />
                                    <span class="input-group-text">VND</span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="EditingProperty.Deposit" class="form-label fw-semibold">Đặt cọc (VND)</label>
                                <div class="input-group">
                                    <input asp-for="EditingProperty.Deposit" type="number" class="form-control border-2" />
                                    <span class="input-group-text">VND</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EditingProperty.Area" class="form-label fw-semibold">Diện tích (m²)</label>
                                <input asp-for="EditingProperty.Area" type="number" class="form-control border-2" step="any" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EditingProperty.MaxOccupants" class="form-label fw-semibold">Số người tối đa</label>
                                <input asp-for="EditingProperty.MaxOccupants" type="number" class="form-control border-2" />
                            </div>
                            <div class="col-12 mt-4">
                                <label class="form-label fw-bold text-secondary text-uppercase small">Địa chỉ</label>
                                <div class="row g-3">
                                    <div class="col-md-4"><input asp-for="EditingProperty.City" class="form-control border-2" /></div>
                                    <div class="col-md-4"><input asp-for="EditingProperty.District" class="form-control border-2" /></div>
                                    <div class="col-md-4"><input asp-for="EditingProperty.Ward" class="form-control border-2" /></div>
                                    <div class="col-12"><input asp-for="EditingProperty.Address" class="form-control border-2" required /></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Section 3: Tiện nghi & Dịch vụ -->
                <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                    <div class="card-header bg-info text-white py-3">
                        <h5 class="mb-0"><i class="fas fa-concierge-bell me-2"></i>3. Tiện nghi & Dịch vụ</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row">
                            @{
                                var categories = Model.AvailableAmenities.Select(a => a.Category).Distinct().ToList();
                                foreach (var cat in categories)
                                {
                                    <div class="col-md-4 mb-4">
                                        <h6 class="fw-bold text-uppercase text-secondary mb-3 small">
                                            @if(cat == "basic") { <text>Cơ bản</text> }
                                            else if(cat == "furniture") { <text>Nội thất</text> }
                                            else if(cat == "security") { <text>An ninh</text> }
                                            else { @cat }
                                        </h6>
                                        <div class="d-flex flex-column gap-2">
                                            @foreach (var amenity in Model.AvailableAmenities.Where(a => a.Category == cat))
                                            {
                                                <div class="form-check custom-checkbox">
                                                    <input class="form-check-input" type="checkbox" name="SelectedAmenityIds" 
                                                           value="@amenity.AmenityId" id="amenity_@amenity.AmenityId"
                                                           @(Model.SelectedAmenityIds.Contains(amenity.AmenityId) ? "checked" : "")>
                                                    <label class="form-check-label" for="amenity_@amenity.AmenityId">
                                                        @if(!string.IsNullOrEmpty(amenity.IconUrl)) { <i class="@amenity.IconUrl me-1"></i> }
                                                        @amenity.Name
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>

                <!-- Section 4: Hình ảnh & Media 360 -->
                <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                    <div class="card-header bg-dark text-white py-3">
                        <h5 class="mb-0"><i class="fas fa-images me-2"></i>4. Hình ảnh & Media 360</h5>
                    </div>
                    <div class="card-body p-4">
                        <!-- Ảnh hiện có -->
                        @if (Model.ExistingImages.Any())
                        {
                            <label class="form-label fw-bold mb-3 text-secondary">Ảnh hiện có (@Model.ExistingImages.Count)</label>
                            <div class="row g-3 mb-4 p-3 bg-light rounded shadow-inner" id="existingImagesContainer">
                                @foreach (var img in Model.ExistingImages)
                                {
                                    <div class="col-6 col-md-3 col-lg-2 position-relative img-item" id="img-container-@img.ImageId">
                                        <img src="@img.ImageUrl" class="img-thumbnail w-100 shadow-sm" style="height: 120px; object-fit: cover;">
                                        @if (img.ImageUrl.Contains("_360"))
                                        {
                                            <span class="badge bg-info position-absolute top-0 start-0 m-2">360°</span>
                                        }
                                        <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 m-2 shadow-sm" 
                                                onclick="deleteImage(@img.ImageId)">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                        }

                        <div class="row g-4 mt-2">
                            <div class="col-md-6 border-end">
                                <label class="form-label fw-bold"><i class="fas fa-camera me-1"></i> Tải thêm Ảnh thường</label>
                                <label class="btn btn-outline-secondary w-100 py-4 border-dashed mb-2" style="border: 2px dashed #ccc;">
                                    <i class="fas fa-upload d-block mb-2"></i>
                                    <span>Chọn ảnh mới</span>
                                    <input type="file" asp-for="UploadedImages" multiple accept="image/*" class="d-none" id="imgInput" />
                                </label>
                                <div id="imagePreview" class="row g-2 mt-2"></div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-info"><i class="fas fa-street-view me-1"></i> Tải thêm Ảnh 360°</label>
                                <label class="btn btn-outline-info w-100 py-4 border-dashed mb-2" style="border: 2px dashed #0dcaf0;">
                                    <i class="fas fa-vr-cardboard d-block mb-2 text-info"></i>
                                    <span>Chọn ảnh 360° mới</span>
                                    <input type="file" asp-for="Uploaded360Images" accept="image/*" class="d-none" id="img360Input" />
                                </label>
                                <div id="image360Preview" class="row g-2 mt-2"></div>
                                <small class="text-info d-block mt-1">Lưu ý: Chỉ được phép có tối đa 1 ảnh 360°. Nếu tải lên ảnh mới, hệ thống sẽ ưu tiên ảnh mới này.</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sticky Action Bar -->
                <div class="card shadow-lg border-0 bg-light sticky-bottom mt-5">
                    <div class="card-body p-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <div class="me-3">
                                <label asp-for="EditingListing.Status" class="form-label mb-0 fw-bold me-2">Trạng thái:</label>
                                <select asp-for="EditingListing.Status" class="form-select d-inline-block w-auto">
                                    <option value="active">Đang hiển thị</option>
                                    <option value="draft">Bản nháp</option>
                                    <option value="inactive">Đã ẩn</option>
                                </select>
                            </div>
                        </div>
                        <div class="gap-2 d-flex">
                            <button type="submit" class="btn btn-primary btn-lg px-5 shadow">
                                <i class="fas fa-save me-2"></i>Lưu Thay đổi
                            </button>
                        </div>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Sử dụng DataTransfer để có thể xóa file trong input[type=file]
        let normalFiles = new DataTransfer();
        let files360 = new DataTransfer();

        const imgInput = document.getElementById('imgInput');
        const img360Input = document.getElementById('img360Input');

        function updatePreview(inputId, previewId, dt, is360) {
            const preview = document.getElementById(previewId);
            const input = document.getElementById(inputId);
            preview.innerHTML = '';
            
            Array.from(dt.files).forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = function(re) {
                    const col = document.createElement('div');
                    col.className = 'col-3 position-relative preview-item animate__animated animate__fadeIn';
                    let badge = is360 ? '<span class="badge bg-info position-absolute top-0 start-0 m-1" style="z-index:10">360°</span>' : '';
                    col.innerHTML = `
                        ${badge}
                        <img src="${re.target.result}" class="img-thumbnail" style="height: 100px; width: 100%; object-fit: cover;">
                        <button type="button" class="btn btn-danger btn-sm rounded-circle position-absolute top-0 end-0 m-1 shadow-sm" 
                                style="width:24px; height:24px; padding:0; display:flex; align-items:center; justify-content:center; z-index:11"
                                onclick="removeSelectedFile('${inputId}', '${previewId}', ${index}, ${is360})">
                            <i class="fas fa-times"></i>
                        </button>
                    `;
                    preview.appendChild(col);
                }
                reader.readAsDataURL(file);
            });
            // Đồng bộ lại file vào input thực tế
            input.files = dt.files;
        }

        function removeSelectedFile(inputId, previewId, index, is360) {
            let dt = is360 ? files360 : normalFiles;
            const newDt = new DataTransfer();
            Array.from(dt.files).forEach((file, i) => {
                if (i !== index) newDt.items.add(file);
            });
            
            if (is360) files360 = newDt; else normalFiles = newDt;
            updatePreview(inputId, previewId, is360 ? files360 : normalFiles, is360);
        }

        imgInput.addEventListener('change', function(e) {
            // Append thay vì reset để người dùng chọn nhiều lần
            Array.from(e.target.files).forEach(file => normalFiles.items.add(file));
            updatePreview('imgInput', 'imagePreview', normalFiles, false);
        });

        img360Input.addEventListener('change', function(e) {
            files360 = new DataTransfer(); // Reset để chỉ lấy 1 ảnh mới nhất
            Array.from(e.target.files).forEach(file => files360.items.add(file));
            updatePreview('img360Input', 'image360Preview', files360, true);
        });

        async function deleteImage(imageId) {
            if (!confirm('Bạn có chắc chắn muốn xóa ảnh này?')) return;

            try {
                // Sử dụng Fetch để gọi handler mà không reload trang
                // Cần truyền Verification Token của ASP.NET Core
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const response = await fetch(`?handler=DeleteImage&imageId=${imageId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    }
                });

                if (response.ok) {
                    const container = document.getElementById(`img-container-${imageId}`);
                    if (container) {
                        container.style.opacity = '0';
                        setTimeout(() => {
                            container.remove();
                            // Cập nhật lại số lượng ảnh trong label nếu cần
                        }, 300);
                    }
                } else {
                    alert('Lỗi khi xóa ảnh. Vui lòng thử lại.');
                }
            } catch (err) {
                console.error(err);
                alert('Lỗi kết nối máy chủ.');
            }
        }
    </script>
}

<style>
    .border-dashed:hover {
        background: #f0f4ff !important;
        cursor: pointer;
    }
    .sticky-bottom {
        bottom: 1rem;
        z-index: 1020;
    }
    .shadow-inner {
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.06);
    }
</style>
