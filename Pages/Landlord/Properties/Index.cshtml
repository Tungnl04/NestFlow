@page
@model NestFlow.Pages.Landlord.Properties.IndexModel
@{
    ViewData["Title"] = "Quản lý phòng trọ";
    Layout = "_LandlordLayout";
}

<!-- CSS -->
<style>
    .building-selector-section {
        background: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
    }

    .statistics-section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 15px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
    }

    .stat-content h3 {
        margin: 0;
        font-size: 28px;
        font-weight: bold;
        color: #333;
    }

    .stat-content p {
        margin: 0;
        color: #666;
        font-size: 14px;
    }

    .floor-section {
        background: white;
        margin-bottom: 20px;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .floor-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 15px 20px;
        font-size: 18px;
        font-weight: bold;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .rooms-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 15px;
        padding: 20px;
    }

    .room-card {
        border: 3px solid;
        border-radius: 10px;
        padding: 15px;
        cursor: pointer;
        transition: all 0.3s;
        text-align: center;
        position: relative;
    }

        .room-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.2);
        }

        .room-card.status-available {
            background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
            border-color: #28a745;
        }

        .room-card.status-occupied {
            background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
            border-color: #dc3545;
        }

        .room-card.status-maintenance {
            background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%);
            border-color: #ffc107;
        }

        .room-card.status-inactive {
            background: linear-gradient(135deg, #e2e3e5 0%, #d6d8db 100%);
            border-color: #6c757d;
            opacity: 0.7;
        }

    .room-number {
        font-size: 24px;
        font-weight: bold;
        margin-bottom: 8px;
        color: #333;
    }

    .room-status {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 15px;
        font-size: 12px;
        font-weight: bold;
        margin-bottom: 8px;
        color: white;
    }

    .status-available .room-status {
        background: #28a745;
    }

    .status-occupied .room-status {
        background: #dc3545;
    }

    .status-maintenance .room-status {
        background: #ffc107;
        color: #333;
    }

    .status-inactive .room-status {
        background: #6c757d;
    }

    .room-info {
        font-size: 13px;
        color: #555;
    }

    .room-renter {
        margin-top: 8px;
        padding-top: 8px;
        border-top: 1px solid rgba(0,0,0,0.1);
        font-weight: bold;
        color: #333;
    }

    .modal {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.5);
        overflow-y: auto;
    }

    .modal-content {
        background-color: white;
        margin: 50px auto;
        padding: 0;
        border-radius: 10px;
        width: 90%;
        max-width: 800px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

    .modal-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 20px;
        border-radius: 10px 10px 0 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .modal-header h2 {
            margin: 0;
            font-size: 24px;
        }

    .modal-body {
        padding: 20px;
        max-height: 70vh;
        overflow-y: auto;
    }

    .modal-footer {
        padding: 15px 20px;
        border-top: 1px solid #ddd;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .close {
        color: white;
        font-size: 28px;
        font-weight: bold;
        cursor: pointer;
        background: none;
        border: none;
        opacity: 0.8;
    }

        .close:hover {
            opacity: 1;
        }

    .detail-section {
        margin-bottom: 25px;
    }

        .detail-section h3 {
            color: #667eea;
            font-size: 18px;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid #667eea;
        }

    .detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
    }

    .detail-item {
        padding: 10px;
        background: #f8f9fa;
        border-radius: 5px;
    }

    .detail-label {
        font-size: 12px;
        color: #666;
        margin-bottom: 5px;
    }

    .detail-value {
        font-size: 16px;
        font-weight: bold;
        color: #333;
    }

    .occupants-list {
        list-style: none;
        padding: 0;
    }

    .occupant-item {
        padding: 12px;
        background: #f8f9fa;
        border-radius: 8px;
        margin-bottom: 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .occupant-info {
        flex: 1;
    }

    .occupant-name {
        font-weight: bold;
        color: #333;
        margin-bottom: 5px;
    }

    .occupant-details {
        font-size: 13px;
        color: #666;
    }

    .invoice-card {
        background: #fff3cd;
        border: 2px solid #ffc107;
        border-radius: 8px;
        padding: 15px;
    }

    .invoice-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid rgba(0,0,0,0.1);
    }

        .invoice-row:last-child {
            border-bottom: none;
            font-weight: bold;
            font-size: 18px;
            margin-top: 10px;
            padding-top: 10px;
            border-top: 2px solid #ffc107;
        }

    .form-group {
        margin-bottom: 15px;
    }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            color: #333;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-size: 14px;
        }

            .form-group input:focus,
            .form-group select:focus,
            .form-group textarea:focus {
                outline: none;
                border-color: #667eea;
                box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
            }

    .btn {
        padding: 10px 20px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        font-size: 14px;
        font-weight: bold;
        transition: all 0.3s;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
        }

    .btn-secondary {
        background: #6c757d;
        color: white;
    }

    .btn-success {
        background: #28a745;
        color: white;
    }

    .btn-danger {
        background: #dc3545;
        color: white;
    }

    .btn-warning {
        background: #ffc107;
        color: #333;
    }

    .btn-sm {
        padding: 6px 12px;
        font-size: 12px;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #666;
    }

        .empty-state i {
            font-size: 64px;
            color: #ddd;
            margin-bottom: 20px;
        }

    .loading {
        text-align: center;
        padding: 40px;
        color: #666;
    }

    .spinner {
        border: 3px solid #f3f3f3;
        border-top: 3px solid #667eea;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
        margin: 0 auto 15px;
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .alert {
        padding: 15px 20px;
        border-radius: 5px;
        margin-bottom: 20px;
        position: relative;
    }

    .alert-success {
        background: #d4edda;
        border: 1px solid #c3e6cb;
        color: #155724;
    }

    .alert-danger {
        background: #f8d7da;
        border: 1px solid #f5c6cb;
        color: #721c24;
    }

    .alert-warning {
        background: #fff3cd;
        border: 1px solid #ffeaa7;
        color: #856404;
    }

    .filters-section {
        background: white;
        padding: 15px 20px;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
        align-items: center;
    }

    .filter-item {
        flex: 1;
        min-width: 200px;
    }

        .filter-item input,
        .filter-item select {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 5px;
        }

    /* =============================================
           TOAST NOTIFICATION
        ============================================= */
    #toastContainer {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 99999;
        display: flex;
        flex-direction: column;
        gap: 10px;
        pointer-events: none;
    }

    .toast-notification {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        min-width: 320px;
        max-width: 420px;
        padding: 16px 18px;
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.18), 0 2px 8px rgba(0,0,0,0.10);
        font-size: 14px;
        font-weight: 500;
        pointer-events: all;
        animation: toastSlideIn 0.35s cubic-bezier(.21,1.02,.73,1) forwards;
        position: relative;
        overflow: hidden;
    }

        .toast-notification.toast-hide {
            animation: toastSlideOut 0.3s ease forwards;
        }

        .toast-notification.toast-success {
            background: #fff;
            border-left: 5px solid #28a745;
            color: #1a5c2e;
        }

        .toast-notification.toast-danger {
            background: #fff;
            border-left: 5px solid #dc3545;
            color: #7b1520;
        }

        .toast-notification.toast-warning {
            background: #fff;
            border-left: 5px solid #ffc107;
            color: #6b4e00;
        }

        .toast-notification.toast-info {
            background: #fff;
            border-left: 5px solid #667eea;
            color: #2c3a7a;
        }

    .toast-icon {
        font-size: 20px;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .toast-notification.toast-success .toast-icon {
        color: #28a745;
    }

    .toast-notification.toast-danger .toast-icon {
        color: #dc3545;
    }

    .toast-notification.toast-warning .toast-icon {
        color: #ffc107;
    }

    .toast-notification.toast-info .toast-icon {
        color: #667eea;
    }

    .toast-body {
        flex: 1;
        line-height: 1.5;
    }

    .toast-title {
        font-weight: 700;
        margin-bottom: 2px;
        font-size: 14px;
    }

    .toast-message {
        font-size: 13px;
        opacity: 0.85;
    }

    .toast-close {
        background: none;
        border: none;
        cursor: pointer;
        color: #aaa;
        font-size: 18px;
        padding: 0;
        line-height: 1;
        flex-shrink: 0;
        transition: color 0.2s;
    }

        .toast-close:hover {
            color: #555;
        }

    .toast-progress {
        position: absolute;
        bottom: 0;
        left: 0;
        height: 3px;
        border-radius: 0 0 0 12px;
        animation: toastProgress 4s linear forwards;
    }

    .toast-success .toast-progress {
        background: #28a745;
    }

    .toast-danger .toast-progress {
        background: #dc3545;
    }

    .toast-warning .toast-progress {
        background: #ffc107;
    }

    .toast-info .toast-progress {
        background: #667eea;
    }

    @@keyframes toastSlideIn {
        from {
            opacity: 0;
            transform: translateX(60px) scale(0.95);
        }

        to {
            opacity: 1;
            transform: translateX(0) scale(1);
        }
    }

    @@keyframes toastSlideOut {
        from {
            opacity: 1;
            transform: translateX(0);
        }

        to {
            opacity: 0;
            transform: translateX(60px);
        }
    }

    @@keyframes toastProgress {
        from {
            width: 100%;
        }

        to {
            width: 0%;
        }
    }

    /* =============================================
           CUSTOM DIALOG MODAL (replaces confirm/prompt)
        ============================================= */
    #dialogOverlay {
        display: none;
        position: fixed;
        z-index: 90000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.55);
        backdrop-filter: blur(3px);
        align-items: center;
        justify-content: center;
    }

        #dialogOverlay.active {
            display: flex;
        }

    .dialog-box {
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        width: 90%;
        max-width: 480px;
        overflow: hidden;
        animation: dialogPop 0.3s cubic-bezier(.21,1.02,.73,1) forwards;
    }

    @@keyframes dialogPop {
        from {
            opacity: 0;
            transform: scale(0.88) translateY(20px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .dialog-header {
        padding: 22px 24px 16px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .dialog-icon-wrap {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
    }

        .dialog-icon-wrap.icon-danger {
            background: #fde8ea;
            color: #dc3545;
        }

        .dialog-icon-wrap.icon-warning {
            background: #fff5d6;
            color: #e08f00;
        }

        .dialog-icon-wrap.icon-info {
            background: #eef0fd;
            color: #667eea;
        }

    .dialog-title {
        font-size: 18px;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
    }

    .dialog-subtitle {
        font-size: 13px;
        color: #888;
        margin: 2px 0 0;
    }

    .dialog-body {
        padding: 0 24px 20px;
        color: #444;
        font-size: 14px;
        line-height: 1.6;
    }

        .dialog-body p {
            margin: 0 0 14px;
        }

    .dialog-field {
        margin-top: 14px;
    }

        .dialog-field label {
            display: block;
            font-weight: 600;
            font-size: 13px;
            color: #555;
            margin-bottom: 6px;
        }

        .dialog-field input {
            width: 100%;
            padding: 10px 14px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 14px;
            color: #333;
            transition: border-color 0.2s;
            box-sizing: border-box;
        }

            .dialog-field input:focus {
                outline: none;
                border-color: #667eea;
                box-shadow: 0 0 0 3px rgba(102,126,234,0.12);
            }

    .dialog-footer {
        padding: 16px 24px;
        background: #f8f9fa;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        border-top: 1px solid #f0f0f0;
    }

    .dialog-btn {
        padding: 10px 22px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .dialog-btn-cancel {
        background: #f0f0f0;
        color: #555;
    }

        .dialog-btn-cancel:hover {
            background: #e4e4e4;
        }

    .dialog-btn-confirm-danger {
        background: linear-gradient(135deg, #dc3545, #c82333);
        color: white;
        box-shadow: 0 3px 10px rgba(220,53,69,0.3);
    }

        .dialog-btn-confirm-danger:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 14px rgba(220,53,69,0.4);
        }

    .dialog-btn-confirm-warning {
        background: linear-gradient(135deg, #ffc107, #e0a800);
        color: #333;
        box-shadow: 0 3px 10px rgba(255,193,7,0.3);
    }

        .dialog-btn-confirm-warning:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 14px rgba(255,193,7,0.4);
        }

    .dialog-btn-confirm-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        box-shadow: 0 3px 10px rgba(102,126,234,0.3);
    }

        .dialog-btn-confirm-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 14px rgba(102,126,234,0.4);
        }
</style>

<!-- Toast Container -->
<div id="toastContainer"></div>

<!-- Custom Dialog Overlay -->
<div id="dialogOverlay">
    <div class="dialog-box" id="dialogBox">
        <div class="dialog-header">
            <div class="dialog-icon-wrap" id="dialogIconWrap">
                <i id="dialogIcon" class="fas fa-exclamation-triangle"></i>
            </div>
            <div>
                <p class="dialog-title" id="dialogTitle">Xác nhận</p>
                <p class="dialog-subtitle" id="dialogSubtitle"></p>
            </div>
        </div>
        <div class="dialog-body" id="dialogBody"></div>
        <div class="dialog-footer" id="dialogFooter"></div>
    </div>
</div>

<!-- HTML Content -->
<div class="container-fluid px-4 py-4">
    <h1 class="mb-4">
        <i class="fas fa-building"></i> Quản lý phòng trọ
    </h1>

    <!-- Building Selector -->
    <div class="building-selector-section">
        <div class="row align-items-center">
            <div class="col-md-8">
                <label for="buildingSelector" class="form-label fw-bold">
                    <i class="fas fa-home"></i> Chọn nhà trọ:
                </label>
                <select id="buildingSelector" class="form-select form-select-lg">
                    <option value="">-- Đang tải danh sách nhà trọ... --</option>
                </select>
            </div>
            <div class="col-md-4 text-end">
                <button class="btn btn-success" onclick="showCreateBuildingModal()">
                    <i class="fas fa-plus"></i> Tạo nhà trọ mới
                </button>
            </div>
        </div>
    </div>

    <!-- Statistics -->
    <div id="statisticsSection" class="statistics-section" style="display: none;">
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <i class="fas fa-door-open"></i>
            </div>
            <div class="stat-content">
                <h3 id="totalRooms">0</h3>
                <p>Tổng số phòng</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%);">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-content">
                <h3 id="availableRooms">0</h3>
                <p>Phòng trống</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #dc3545 0%, #fd7e14 100%);">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-content">
                <h3 id="occupiedRooms">0</h3>
                <p>Đang cho thuê</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #ffc107 0%, #ff6b6b 100%);">
                <i class="fas fa-coins"></i>
            </div>
            <div class="stat-content">
                <h3 id="monthlyRevenue">0đ</h3>
                <p>Doanh thu/tháng</p>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div id="filtersSection" class="filters-section" style="display: none;">
        <div class="filter-item">
            <input type="text" id="searchRoom" placeholder="🔍 Tìm phòng theo mã...">
        </div>
        <div class="filter-item">
            <select id="statusFilter">
                <option value="">Tất cả trạng thái</option>
                <option value="available">Trống</option>
                <option value="occupied">Đang thuê</option>
                <option value="maintenance">Bảo trì</option>
                <option value="inactive">Ngừng hoạt động</option>
            </select>
        </div>
        <button class="btn btn-primary" onclick="applyFilters()">
            <i class="fas fa-filter"></i> Lọc
        </button>
        <button class="btn btn-secondary" onclick="clearFilters()">
            <i class="fas fa-redo"></i> Đặt lại
        </button>
        <button class="btn btn-success" onclick="showAddRoomModal()">
            <i class="fas fa-plus"></i> Thêm phòng
        </button>
    </div>

    <!-- Loading State -->
    <div id="loadingState" class="loading" style="display: none;">
        <div class="spinner"></div>
        <p>Đang tải dữ liệu...</p>
    </div>

    <!-- Floors Container -->
    <div id="floorsContainer"></div>

    <!-- Empty State -->
    <div id="emptyState" class="empty-state" style="display: none;">
        <i class="fas fa-building"></i>
        <h3>Chưa có nhà trọ nào</h3>
        <p>Vui lòng tạo nhà trọ mới để bắt đầu quản lý phòng trọ</p>
        <button class="btn btn-primary" onclick="showCreateBuildingModal()">
            <i class="fas fa-plus"></i> Tạo nhà trọ ngay
        </button>
    </div>
</div>

<!-- Modal: Setup Building (First Time) -->
<div id="setupModal" class="modal">
    <div class="modal-content" style="max-width: 560px;">
        <div class="modal-header">
            <h2><i class="fas fa-cog"></i> Thiết lập nhà trọ</h2>
            <button class="close" onclick="closeSetupModal()">&times;</button>
        </div>
        <div class="modal-body">
            <p>Nhà trọ này chưa được thiết lập. Vui lòng nhập thông tin:</p>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Số tầng:</label>
                        <input type="number" id="totalFloors" min="1" max="20" value="3" class="form-control">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Số phòng mỗi tầng:</label>
                        <input type="number" id="roomsPerFloor" min="1" max="50" value="4" class="form-control">
                    </div>
                </div>
            </div>

            <hr style="margin: 15px 0; border-color: #e0e0e0;">
            <h6 style="color: #667eea; font-weight: 700; margin-bottom: 12px;">
                <i class="fas fa-door-open"></i> Thông tin mặc định cho mỗi phòng
            </h6>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Diện tích (m²):</label>
                        <input type="number" id="setupDefaultArea" min="1" step="0.1" value="25" class="form-control">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Số người tối đa:</label>
                        <input type="number" id="setupDefaultMaxOccupants" min="1" value="2" class="form-control">
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Giá thuê (đ/tháng):</label>
                        <input type="number" id="setupDefaultPrice" min="0" step="100000" value="2000000" class="form-control">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>Tiền cọc (đ):</label>
                        <input type="number" id="setupDefaultDeposit" min="0" step="100000" value="2000000" class="form-control">
                    </div>
                </div>
            </div>

            <div class="alert alert-warning" style="margin-top: 5px;">
                <i class="fas fa-info-circle"></i>
                <strong>Lưu ý:</strong> Hệ thống sẽ tự động tạo tất cả các phòng với thông tin trên.
                Bạn có thể chỉnh sửa từng phòng sau.
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeSetupModal()">Hủy</button>
            <button class="btn btn-primary" onclick="initializeBuilding()">
                <i class="fas fa-check"></i> Khởi tạo
            </button>
        </div>
    </div>
</div>

<!-- Modal: Room Detail -->
<div id="roomDetailModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="roomDetailTitle">Chi tiết phòng</h2>
            <button class="close" onclick="closeRoomDetailModal()">&times;</button>
        </div>
        <div class="modal-body" id="roomDetailContent">
            <!-- Content loaded via JavaScript -->
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeRoomDetailModal()">Đóng</button>
        </div>
    </div>
</div>

<!-- Modal: Add Occupant -->
<div id="addOccupantModal" class="modal">
    <div class="modal-content" style="max-width: 600px;">
        <div class="modal-header">
            <h2><i class="fas fa-user-plus"></i> Thêm người thuê</h2>
            <button class="close" onclick="closeAddOccupantModal()">&times;</button>
        </div>
        <div class="modal-body">
            <form id="addOccupantForm">
                <input type="hidden" id="occupantPropertyId">

                <div class="form-group">
                    <label>Họ và tên: <span class="text-danger">*</span></label>
                    <input type="text" id="occupantFullName" required>
                </div>

                <div class="form-group">
                    <label>Số điện thoại:</label>
                    <input type="tel" id="occupantPhone">
                </div>

                <div class="form-group">
                    <label>Số CMND/CCCD:</label>
                    <input type="text" id="occupantIdNumber">
                </div>

                <div class="form-group">
                    <label>Ngày vào ở: <span class="text-danger">*</span></label>
                    <input type="date" id="occupantMoveInDate" required>
                </div>

                <div class="form-group">
                    <label>Ngày dự kiến chuyển đi:</label>
                    <input type="date" id="occupantMoveOutExpected">
                </div>

                <div class="form-group">
                    <label>
                        <input type="checkbox" id="occupantIsPrimary">
                        Là người thuê chính (chịu trách nhiệm thanh toán)
                    </label>
                </div>

                <div id="rentalInfoSection" style="display: none;">
                    <hr>
                    <h4>Thông tin thuê (người đầu tiên)</h4>

                    <div class="form-group">
                        <label>Tiền thuê/tháng: <span class="text-danger">*</span></label>
                        <input type="number" id="monthlyRent" min="0" step="100000">
                    </div>

                    <div class="form-group">
                        <label>Tiền cọc: <span class="text-danger">*</span></label>
                        <input type="number" id="depositAmount" min="0" step="100000">
                    </div>

                    <div class="form-group">
                        <label>Ngày đóng tiền hàng tháng:</label>
                        <select id="paymentDueDate">
                            @for (int i = 1; i <= 31; i++)
                            {
                                var selected = i == 5 ? "selected" : "";
                                <option value="@i" selected="@selected">Ngày @i</option>
                            }
                        </select>
                    </div>
                </div>
