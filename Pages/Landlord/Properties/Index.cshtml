            <button class="btn btn-primary" onclick="submitCreateBuilding()">
                <i class="fas fa-save"></i> Tạo nhà trọ
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Global variables
        const LANDLORD_ID = @Model.LandlordId;
        let currentBuildingId = null;
        let currentBuildingData = null;
        let allFloorsData = [];

        // =================================================================
        // TOAST NOTIFICATION SYSTEM
        // =================================================================
        const toastTitles = {
            success: 'Thành công',
            danger: 'Lỗi',
            warning: 'Cảnh báo',
            info: 'Thông báo'
        };

        const toastIcons = {
            success: 'fas fa-check-circle',
            danger: 'fas fa-times-circle',
            warning: 'fas fa-exclamation-triangle',
            info: 'fas fa-info-circle'
        };

        function showAlert(type, message) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast-notification toast-${type}`;

            toast.innerHTML = `
                <div class="toast-icon"><i class="${toastIcons[type] || toastIcons.info}"></i></div>
                <div class="toast-body">
                    <div class="toast-title">${toastTitles[type] || 'Thông báo'}</div>
                    <div class="toast-message">${message}</div>
                </div>
                <button class="toast-close" onclick="dismissToast(this.parentElement)">&times;</button>
                <div class="toast-progress"></div>
            `;

            container.appendChild(toast);

            setTimeout(() => dismissToast(toast), 4800);
        }

        function dismissToast(toast) {
            if (!toast || !toast.parentElement) return;
            toast.classList.add('toast-hide');
            setTimeout(() => toast.remove(), 300);
        }

        // =================================================================
        // CUSTOM DIALOG SYSTEM (replaces confirm + prompt)
        // =================================================================
        let dialogResolve = null;

        function showDialog({ title, subtitle = '', message, icon = 'fas fa-question-circle',
                              iconClass = 'icon-warning', confirmLabel = 'Xác nhận',
                              confirmClass = 'dialog-btn-confirm-warning', cancelLabel = 'Hủy',
                              fields = [] }) {
            return new Promise(resolve => {
                dialogResolve = resolve;

                document.getElementById('dialogTitle').textContent = title;
                document.getElementById('dialogSubtitle').textContent = subtitle;
                document.getElementById('dialogIconWrap').className = `dialog-icon-wrap ${iconClass}`;
                document.getElementById('dialogIcon').className = icon;

                const body = document.getElementById('dialogBody');
                let bodyHtml = message ? `<p>${message}</p>` : '';

                fields.forEach(field => {
                    bodyHtml += `
                        <div class="dialog-field">
                            <label for="dlg_${field.id}">${field.label}</label>
                            <input type="${field.type || 'text'}" id="dlg_${field.id}"
                                   value="${field.defaultValue || ''}"
                                   placeholder="${field.placeholder || ''}"
                                   ${field.required ? 'required' : ''}>
                        </div>
                    `;
                });
                body.innerHTML = bodyHtml;

                const footer = document.getElementById('dialogFooter');
                footer.innerHTML = `
                    <button class="dialog-btn dialog-btn-cancel" onclick="closeDialog(false)">
                        <i class="fas fa-times"></i> ${cancelLabel}
                    </button>
                    <button class="dialog-btn ${confirmClass}" onclick="closeDialog(true)">
                        ${confirmLabel}
                    </button>
                `;

                const overlay = document.getElementById('dialogOverlay');
                overlay.classList.add('active');

                // Focus first input if exists
                setTimeout(() => {
                    const firstInput = overlay.querySelector('input');
                    if (firstInput) firstInput.focus();
                }, 100);
            });
        }

        function closeDialog(confirmed) {
            const overlay = document.getElementById('dialogOverlay');
            overlay.classList.remove('active');

            if (!dialogResolve) return;

            if (!confirmed) {
                dialogResolve(null);
                dialogResolve = null;
                return;
            }

            // Collect field values
            const fields = overlay.querySelectorAll('.dialog-field input');
            if (fields.length === 0) {
                dialogResolve(true);
            } else if (fields.length === 1) {
                dialogResolve(fields[0].value || '');
            } else {
                const result = {};
                fields.forEach(input => {
                    const key = input.id.replace('dlg_', '');
                    result[key] = input.value;
                });
                dialogResolve(result);
            }

            dialogResolve = null;
        }

        // Close dialog on overlay click
        document.getElementById('dialogOverlay').addEventListener('click', function(e) {
            if (e.target === this) closeDialog(false);
        });

        // =================================================================
        // INITIALIZATION
        // =================================================================
        document.addEventListener('DOMContentLoaded', function() {
            loadBuildings();

            document.getElementById('buildingSelector').addEventListener('change', function() {
                const buildingId = this.value;
                if (buildingId) loadBuildingDetail(buildingId);
            });

            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    closeDialog(false);
                    closeAllModals();
                }
                if (e.key === 'Enter') {
                    const overlay = document.getElementById('dialogOverlay');
                    if (overlay.classList.contains('active')) closeDialog(true);
                }
            });
        });

        // =================================================================
        // LOAD BUILDINGS
        // =================================================================
        async function loadBuildings() {
            try {
                const response = await fetch(`/api/building/landlord/${LANDLORD_ID}`);
                const buildings = await response.json();

                const selector = document.getElementById('buildingSelector');
                selector.innerHTML = '<option value="">-- Chọn nhà trọ --</option>';

                if (buildings.length === 0) {
                    document.getElementById('emptyState').style.display = 'block';
                    return;
                }

                buildings.forEach(building => {
                    const option = document.createElement('option');
                    option.value = building.buildingId;
                    option.textContent = `${building.buildingName}`;
                    selector.appendChild(option);
                });

                if (buildings.length > 0) {
                    selector.value = buildings[0].buildingId;
                    loadBuildingDetail(buildings[0].buildingId);
                }
            } catch (error) {
                console.error('Error loading buildings:', error);
                showAlert('danger', 'Lỗi khi tải danh sách nhà trọ');
            }
        }

        // =================================================================
        // LOAD BUILDING DETAIL
        // =================================================================
        async function loadBuildingDetail(buildingId) {
            showLoading();
            currentBuildingId = buildingId;

            try {
                const response = await fetch(`/api/building/${buildingId}/landlord/${LANDLORD_ID}`);
                const building = await response.json();
                currentBuildingData = building;

                if (!building.isSetupCompleted) {
                    hideLoading();
                    showSetupModal();
                    return;
                }

                displayStatistics(building.statistics);
                allFloorsData = building.floors;
                displayFloors(building.floors);

                document.getElementById('statisticsSection').style.display = 'grid';
                document.getElementById('filtersSection').style.display = 'flex';
                document.getElementById('emptyState').style.display = 'none';

                hideLoading();
            } catch (error) {
                console.error('Error loading building detail:', error);
                hideLoading();
                showAlert('danger', 'Lỗi khi tải thông tin nhà trọ');
            }
        }

        // =================================================================
        // DISPLAY STATISTICS
        // =================================================================
        function displayStatistics(stats) {
            document.getElementById('totalRooms').textContent = stats.totalRooms;
            document.getElementById('availableRooms').textContent = stats.availableRooms;
            document.getElementById('occupiedRooms').textContent = stats.occupiedRooms;
            document.getElementById('monthlyRevenue').textContent = formatPrice(stats.monthlyRevenue);
        }

        // =================================================================
        // DISPLAY FLOORS
        // =================================================================
        function displayFloors(floors) {
            const container = document.getElementById('floorsContainer');
            container.innerHTML = '';

            if (!floors || floors.length === 0) {
                container.innerHTML = '<div class="empty-state"><p>Chưa có tầng nào</p></div>';
                return;
            }

            const sortedFloors = [...floors].sort((a, b) => b.floorNumber - a.floorNumber);

            sortedFloors.forEach(floor => {
                const floorDiv = document.createElement('div');
                floorDiv.className = 'floor-section';

                floorDiv.innerHTML = `
                    <div class="floor-header">
                        <span><i class="fas fa-layer-group"></i> ${floor.floorName}</span>
                        <span>${floor.rooms.length} phòng</span>
                    </div>
                    <div class="rooms-grid" id="floor-${floor.floorId}"></div>
                `;

                container.appendChild(floorDiv);

                const roomsGrid = document.getElementById(`floor-${floor.floorId}`);
                floor.rooms.forEach(room => {
                    roomsGrid.appendChild(createRoomCard(room));
                });
            });
        }

        // =================================================================
        // CREATE ROOM CARD
        // =================================================================
        function createRoomCard(room) {
            const card = document.createElement('div');
            card.className = `room-card status-${room.status}`;
            card.onclick = () => showRoomDetail(room.propertyId);

            let renterInfo = '';
            if (room.renterName) {
                renterInfo = `
                    <div class="room-renter">
                        <i class="fas fa-user"></i> ${room.renterName}
                    </div>
                `;
            }

            card.innerHTML = `
                <div class="room-number">${room.roomNumber}</div>
                <div class="room-status">${room.statusDisplay}</div>
                <div class="room-info">
                    <div><i class="fas fa-ruler-combined"></i> ${room.area}m²</div>
                    <div><i class="fas fa-money-bill-wave"></i> ${formatPrice(room.price)}</div>
                    <div><i class="fas fa-users"></i> ${room.currentOccupants}/${room.maxOccupants} người</div>
                </div>
                ${renterInfo}
            `;

            return card;
        }

        // =================================================================
        // SHOW ROOM DETAIL
        // =================================================================
        async function showRoomDetail(propertyId) {
            const modal = document.getElementById('roomDetailModal');
            const content = document.getElementById('roomDetailContent');
            const title = document.getElementById('roomDetailTitle');

            content.innerHTML = '<div class="loading"><div class="spinner"></div><p>Đang tải...</p></div>';
            modal.style.display = 'block';

            try {
                const response = await fetch(`/api/room/${propertyId}/landlord/${LANDLORD_ID}`);
                const room = await response.json();

                title.textContent = `Phòng ${room.roomNumber} - ${room.statusDisplay}`;

                let html = `
                    <div class="detail-section">
                        <h3><i class="fas fa-info-circle"></i> Thông tin phòng</h3>
                        <div class="detail-grid">
                            <div class="detail-item">
                                <div class="detail-label">Diện tích</div>
                                <div class="detail-value">${room.area}m²</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Giá thuê</div>
                                <div class="detail-value">${formatPrice(room.price)}/tháng</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Tiền cọc</div>
                                <div class="detail-value">${formatPrice(room.deposit)}</div>
                            </div>
                            <div class="detail-item">
                                <div class="detail-label">Số người tối đa</div>
                                <div class="detail-value">${room.maxOccupants} người</div>
                            </div>
                        </div>
                        ${room.amenities.length > 0 ? `
                            <div style="margin-top: 15px;">
                                <strong>Tiện nghi:</strong> ${room.amenities.join(', ')}
                            </div>
                        ` : ''}
                    </div>
                `;

                const rental = room.currentRental;

                if (rental) {
                    html += `
                        <div class="detail-section">
                            <h3><i class="fas fa-users"></i> Người thuê hiện tại (${room.currentRental.occupants.length}/${room.maxOccupants})</h3>
                            <ul class="occupants-list">
                                ${rental.occupants.map(occ => `
                                    <li class="occupant-item">
                                        <div class="occupant-info">
                                            <div class="occupant-name">
                                                ${occ.fullName} ${occ.isPrimaryRenter ? '<span class="badge bg-primary">Người thuê chính</span>' : ''}
                                            </div>
                                            <div class="occupant-details">
                                                ${occ.phone ? `<i class="fas fa-phone"></i> ${occ.phone}` : ''}
                                                ${occ.idNumber ? ` | <i class="fas fa-id-card"></i> ${occ.idNumber}` : ''}
                                            </div>
                                        </div>
                                        <button class="btn btn-danger btn-sm" onclick="removeOccupant(${occ.occupantId}, '${occ.fullName}')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </li>
                                `).join('')}
                            </ul>

                            <div class="mt-3">
                                <strong>Thời gian thuê:</strong> ${formatDate(rental.startDate)}
                                ${rental.endDate ? ` → ${formatDate(rental.endDate)}` : ''}
                                ${rental.daysRemaining > 0 ? `<span class="text-muted">(còn ${rental.daysRemaining} ngày)</span>` : ''}
                            </div>

                            <div class="mt-2">
                                <button class="btn btn-warning" onclick="endRental(${rental.rentalId})">
                                    <i class="fas fa-stop-circle"></i> Kết thúc hợp đồng
                                </button>
                            </div>
                        </div>
                    `;
                }

                if (room.currentRental && room.latestInvoice) {
                    const inv = room.latestInvoice;
                    html += `
                        <div class="detail-section">
                            <h3><i class="fas fa-file-invoice-dollar"></i> Hóa đơn tháng ${inv.invoiceMonth}</h3>
                            <div class="invoice-card">
                                <div class="invoice-row">
                                    <span>Tiền phòng:</span>
                                    <strong>${formatPrice(inv.roomRent)}</strong>
                                </div>
                                <div class="invoice-row">
                                    <span>Tiền điện:</span>
                                    <strong>${formatPrice(inv.electricAmount)}</strong>
                                </div>
                                <div class="invoice-row">
                                    <span>Tiền nước:</span>
                                    <strong>${formatPrice(inv.waterAmount)}</strong>
                                </div>
                                <div class="invoice-row">
                                    <span>Internet:</span>
                                    <strong>${formatPrice(inv.internetFee)}</strong>
                                </div>
                                <div class="invoice-row">
                                    <span>TỔNG CỘNG:</span>
                                    <strong>${formatPrice(inv.totalAmount)}</strong>
                                </div>
                                <div class="mt-2">
                                    Trạng thái: <strong>${inv.status === 'paid' ? '✅ Đã thanh toán' : '⏳ Chưa thanh toán'}</strong>
                                </div>
                            </div>
                        </div>
                    `;
                }

                if (!room.currentRental) {
                    html += `
                        <div class="detail-section">
                            <div class="empty-state">
                                <i class="fas fa-user-plus" style="font-size: 48px;"></i>
                                <p>Phòng chưa có người thuê</p>
                                <button class="btn btn-success" onclick="openAddOccupantModal(${propertyId})">
                                    <i class="fas fa-user-plus"></i> Thêm người thuê
                                </button>
                            </div>
                        </div>
                    `;
                }

                html += `
                    <div class="detail-section">
                        <h3><i class="fas fa-cog"></i> Thao tác</h3>
                        <div class="d-flex gap-2 flex-wrap">
                            ${room.status === 'occupied' && room.currentRental && rental.occupants.length < room.maxOccupants ? `
                                <button class="btn btn-primary" onclick="openAddOccupantModal(${propertyId})">
                                    <i class="fas fa-user-plus"></i> Thêm người ở cùng
                                </button>
                            ` : ''}
                            <button class="btn btn-warning" onclick="editRoom(${propertyId})">
                                <i class="fas fa-edit"></i> Sửa thông tin phòng
                            </button>
                            ${room.status !== 'occupied' ? `
                                <button class="btn btn-danger" onclick="deleteRoom(${propertyId})">
                                    <i class="fas fa-trash"></i> Xóa phòng
                                </button>
                            ` : ''}
                        </div>
                    </div>
                `;

                content.innerHTML = html;
            } catch (error) {
                console.error('Error loading room detail:', error);
                content.innerHTML = '<div class="alert alert-danger">Lỗi khi tải thông tin phòng</div>';
            }
        }

        // =================================================================
        // INITIALIZE BUILDING
        // =================================================================
        async function initializeBuilding() {
            const totalFloors = parseInt(document.getElementById('totalFloors').value);
            const roomsPerFloor = parseInt(document.getElementById('roomsPerFloor').value);
            const defaultArea = parseFloat(document.getElementById('setupDefaultArea').value);
            const defaultMaxOccupants = parseInt(document.getElementById('setupDefaultMaxOccupants').value);
            const defaultPrice = parseFloat(document.getElementById('setupDefaultPrice').value);
            const defaultDeposit = parseFloat(document.getElementById('setupDefaultDeposit').value);

            if (!totalFloors || !roomsPerFloor || totalFloors < 1 || roomsPerFloor < 1) {
                showAlert('warning', 'Vui lòng nhập số tầng và số phòng hợp lệ');
                return;
            }
            if (totalFloors > 20 || roomsPerFloor > 50) {
                showAlert('warning', 'Số tầng tối đa 20, số phòng mỗi tầng tối đa 50');
                return;
            }
            if (!defaultArea || defaultArea <= 0) {
                showAlert('warning', 'Vui lòng nhập diện tích hợp lệ');
                return;
            }
            if (!defaultMaxOccupants || defaultMaxOccupants < 1) {
                showAlert('warning', 'Vui lòng nhập số người tối đa hợp lệ');
                return;
            }
            if (!defaultPrice || defaultPrice < 0) {
                showAlert('warning', 'Vui lòng nhập giá thuê hợp lệ');
                return;
            }

            showLoading();
            closeSetupModal();

            try {
                const response = await fetch(`/api/building/${currentBuildingId}/landlord/${LANDLORD_ID}/initialize`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        totalFloors, roomsPerFloor,
                        defaultArea, defaultMaxOccupants, defaultPrice, defaultDeposit
                    })
                });

                const result = await response.json();

                if (result.success) {
                    showAlert('success', result.message);
                    loadBuildingDetail(currentBuildingId);
                } else {
                    hideLoading();
                    showAlert('danger', result.message);
                }
            } catch (error) {
                console.error('Error initializing building:', error);
                hideLoading();
                showAlert('danger', 'Lỗi khi khởi tạo nhà trọ');
            }
        }

        // =================================================================
        // ADD OCCUPANT
        // =================================================================
        function openAddOccupantModal(propertyId) {
            document.getElementById('occupantPropertyId').value = propertyId;
            document.getElementById('addOccupantForm').reset();

            fetch(`/api/room/${propertyId}/landlord/${LANDLORD_ID}`)
                .then(r => r.json())
                .then(room => {
                    // Kiểm tra đã đủ người chưa
                    if (room.currentRental) {
                        const activeCount = room.currentRental.occupants ? room.currentRental.occupants.length : room.currentOccupants;
                        if (activeCount >= room.maxOccupants) {
                            showAlert('warning', `Phòng đã đủ ${room.maxOccupants} người. Vui lòng cập nhật số người tối đa trước khi thêm.`);
                            return;
                        }
                    }

                    const isFirstOccupant = !room.currentRental;
                    document.getElementById('rentalInfoSection').style.display = isFirstOccupant ? 'block' : 'none';

                    if (isFirstOccupant) {
                        document.getElementById('monthlyRent').value = room.price || 0;
                        document.getElementById('depositAmount').value = room.deposit || 0;
                    }

                    closeRoomDetailModal();
                    document.getElementById('addOccupantModal').style.display = 'block';
                });
        }

        async function submitAddOccupant() {
            const propertyId = document.getElementById('occupantPropertyId').value;
            const fullName = document.getElementById('occupantFullName').value;
            const phone = document.getElementById('occupantPhone').value;
            const idNumber = document.getElementById('occupantIdNumber').value;
            const moveInDate = document.getElementById('occupantMoveInDate').value;
            const moveOutExpected = document.getElementById('occupantMoveOutExpected').value;
            const isPrimary = document.getElementById('occupantIsPrimary').checked;

            if (!fullName || !moveInDate) {
                showAlert('warning', 'Vui lòng nhập họ tên và ngày vào ở');
                return;
            }

            const data = {
                propertyId: parseInt(propertyId),
                fullName, phone, idNumber, moveInDate,
                moveOutExpected: moveOutExpected || null,
                isPrimaryRenter: isPrimary
            };

            const rentalSection = document.getElementById('rentalInfoSection');
            if (rentalSection.style.display !== 'none') {
                data.monthlyRent = parseFloat(document.getElementById('monthlyRent').value);
                data.depositAmount = parseFloat(document.getElementById('depositAmount').value);
                data.paymentDueDate = parseInt(document.getElementById('paymentDueDate').value);

                if (!data.monthlyRent || !data.depositAmount) {
                    showAlert('warning', 'Vui lòng nhập đầy đủ thông tin thuê');
                    return;
                }
            }

            try {
                const response = await fetch(`/api/room/landlord/${LANDLORD_ID}/add-occupant`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    showAlert('success', result.message);
                    closeAddOccupantModal();
                    loadBuildingDetail(currentBuildingId);
                } else {
                    showAlert('danger', result.message);
                }
            } catch (error) {
                console.error('Error adding occupant:', error);
                showAlert('danger', 'Lỗi khi thêm người thuê');
            }
        }

        // =================================================================
        // CREATE BUILDING
        // =================================================================
        function showCreateBuildingModal() {
            document.getElementById('createBuildingForm').reset();
            document.getElementById('createBuildingModal').style.display = 'block';
        }

        async function submitCreateBuilding() {
            const name = document.getElementById('newBuildingName').value.trim();
            const address = document.getElementById('newBuildingAddress').value;
            const ward = document.getElementById('newBuildingWard').value;
            const district = document.getElementById('newBuildingDistrict').value;
            const city = document.getElementById('newBuildingCity').value;
            const description = document.getElementById('newBuildingDescription').value;
            const defaultArea = parseFloat(document.getElementById('newBuildingDefaultArea').value);
            const defaultMaxOccupants = parseInt(document.getElementById('newBuildingDefaultMaxOccupants').value);
            const defaultPrice = parseFloat(document.getElementById('newBuildingDefaultPrice').value);
            const defaultDeposit = parseFloat(document.getElementById('newBuildingDefaultDeposit').value);

            if (!name) {
                showAlert('warning', 'Vui lòng nhập tên nhà trọ');
                return;
            }
            if (!defaultArea || defaultArea <= 0) {
                showAlert('warning', 'Vui lòng nhập diện tích mặc định hợp lệ');
                return;
            }
            if (!defaultMaxOccupants || defaultMaxOccupants < 1) {
                showAlert('warning', 'Vui lòng nhập số người tối đa hợp lệ');
                return;
            }
            if (!defaultPrice || defaultPrice < 0) {
                showAlert('warning', 'Vui lòng nhập giá thuê mặc định hợp lệ');
                return;
            }
            if (defaultDeposit === undefined || defaultDeposit < 0 || isNaN(defaultDeposit)) {
                showAlert('warning', 'Vui lòng nhập tiền cọc mặc định hợp lệ');
                return;
            }

            try {
                const response = await fetch(`/api/building/landlord/${LANDLORD_ID}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        buildingName: name, address, ward, district, city, description,
                        defaultArea, defaultMaxOccupants, defaultPrice, defaultDeposit
                    })
                });

                const result = await response.json();

                if (result.success) {
                    showAlert('success', 'Tạo nhà trọ thành công!');
                    closeCreateBuildingModal();
                    loadBuildings();
                } else {
                    showAlert('danger', result.message);
                }
            } catch (error) {
                console.error('Error creating building:', error);
                showAlert('danger', 'Lỗi khi tạo nhà trọ');
            }
        }

        // =================================================================
        // FILTERS
        // =================================================================
        function applyFilters() {
            const searchText = document.getElementById('searchRoom').value.toLowerCase();
            const statusFilter = document.getElementById('statusFilter').value;

            let filteredFloors = JSON.parse(JSON.stringify(allFloorsData));

            filteredFloors.forEach(floor => {
                floor.rooms = floor.rooms.filter(room => {
                    const matchSearch = !searchText || room.roomNumber.toLowerCase().includes(searchText);
                    const matchStatus = !statusFilter || room.status === statusFilter;
                    return matchSearch && matchStatus;
                });
            });

            displayFloors(filteredFloors);
        }

        function clearFilters() {
            document.getElementById('searchRoom').value = '';
            document.getElementById('statusFilter').value = '';
            displayFloors(allFloorsData);
        }

        // =================================================================
        // UTILITY FUNCTIONS
        // =================================================================
        function formatPrice(price) {
            if (!price) return '0đ';
            return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(price);
        }

        function formatDate(dateString) {
            if (!dateString) return '';
            const date = new Date(dateString);
            return date.toLocaleDateString('vi-VN');
        }

        function showLoading() {
            document.getElementById('loadingState').style.display = 'block';
            document.getElementById('floorsContainer').style.display = 'none';
        }

        function hideLoading() {
            document.getElementById('loadingState').style.display = 'none';
            document.getElementById('floorsContainer').style.display = 'block';
        }

        // =================================================================
        // MODAL FUNCTIONS
        // =================================================================
        function showSetupModal() {
            // Pre-fill từ thông tin building nếu có
            if (currentBuildingData) {
                if (currentBuildingData.defaultArea) document.getElementById('setupDefaultArea').value = currentBuildingData.defaultArea;
                if (currentBuildingData.defaultMaxOccupants) document.getElementById('setupDefaultMaxOccupants').value = currentBuildingData.defaultMaxOccupants;
                if (currentBuildingData.defaultPrice) document.getElementById('setupDefaultPrice').value = currentBuildingData.defaultPrice;
                if (currentBuildingData.defaultDeposit !== undefined) document.getElementById('setupDefaultDeposit').value = currentBuildingData.defaultDeposit;
            }
            document.getElementById('setupModal').style.display = 'block';
        }

        function closeSetupModal() {
            document.getElementById('setupModal').style.display = 'none';
        }

        function closeRoomDetailModal() {
            document.getElementById('roomDetailModal').style.display = 'none';
        }

        function closeAddOccupantModal() {
            document.getElementById('addOccupantModal').style.display = 'none';
        }

        function closeCreateBuildingModal() {
            document.getElementById('createBuildingModal').style.display = 'none';
        }

        function closeAllModals() {
            document.querySelectorAll('.modal').forEach(modal => {
                modal.style.display = 'none';
            });
        }

        window.onclick = function(event) {
            if (event.target.classList.contains('modal')) {
                event.target.style.display = 'none';
            }
        }

        // =================================================================
        // REMOVE OCCUPANT — uses custom dialog
        // =================================================================
        async function removeOccupant(occupantId, occupantName) {
            // Step 1: Confirm
            const confirmed = await showDialog({
                title: 'Xóa người thuê',
                subtitle: occupantName || '',
                message: `Bạn có chắc chắn muốn xóa <strong>${occupantName || 'người thuê này'}</strong> ra khỏi phòng?`,
                icon: 'fas fa-user-minus',
                iconClass: 'icon-danger',
                confirmLabel: '<i class="fas fa-trash"></i> Xóa',
                confirmClass: 'dialog-btn-confirm-danger',
            });

            if (!confirmed) return;

            // Step 2: Move-out date
            const moveOutDate = await showDialog({
                title: 'Ngày chuyển đi',
                subtitle: occupantName || '',
                icon: 'fas fa-calendar-alt',
                iconClass: 'icon-info',
                confirmLabel: '<i class="fas fa-check"></i> Tiếp tục',
                confirmClass: 'dialog-btn-confirm-primary',
                fields: [{
                    id: 'moveOutDate',
                    label: 'Ngày chuyển đi',
                    type: 'date',
                    defaultValue: new Date().toISOString().split('T')[0],
                    required: true
                }]
            });

            if (moveOutDate === null) return;

            // Step 3: Reason
            const reasonResult = await showDialog({
                title: 'Lý do chuyển đi',
                subtitle: 'Tùy chọn — có thể để trống',
                icon: 'fas fa-comment-alt',
                iconClass: 'icon-info',
                confirmLabel: '<i class="fas fa-save"></i> Lưu',
                confirmClass: 'dialog-btn-confirm-primary',
                fields: [{
                    id: 'reason',
                    label: 'Lý do chuyển đi (tùy chọn)',
                    type: 'text',
                    placeholder: 'Nhập lý do hoặc để trống...'
                }]
            });

            if (reasonResult === null) return;

            fetch(`/api/room/landlord/${LANDLORD_ID}/remove-occupant`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    occupantId,
                    moveOutDate: typeof moveOutDate === 'object' ? moveOutDate.moveOutDate : moveOutDate,
                    reason: typeof reasonResult === 'object' ? reasonResult.reason : reasonResult
                })
            })
            .then(r => r.json())
            .then(result => {
                if (result.success) {
                    showAlert('success', result.message);
                    closeRoomDetailModal();
                    loadBuildingDetail(currentBuildingId);
                } else {
                    showAlert('danger', result.message);
                }
            })
            .catch(error => {
                console.error('Error removing occupant:', error);
                showAlert('danger', 'Lỗi khi xóa người thuê');
            });
        }

        // =================================================================
        // END RENTAL — uses custom dialog
        // =================================================================
        async function endRental(rentalId) {
            // Step 1: Confirm
            const confirmed = await showDialog({
                title: 'Kết thúc hợp đồng thuê',
                message: 'Tất cả người thuê sẽ bị xóa và phòng sẽ chuyển về trạng thái <strong>trống</strong>. Hành động này không thể hoàn tác.',
                icon: 'fas fa-stop-circle',
                iconClass: 'icon-danger',
                confirmLabel: '<i class="fas fa-stop-circle"></i> Kết thúc',
                confirmClass: 'dialog-btn-confirm-danger',
            });

            if (!confirmed) return;

            // Step 2: Termination date
            const dateResult = await showDialog({
                title: 'Ngày kết thúc hợp đồng',
                icon: 'fas fa-calendar-times',
                iconClass: 'icon-warning',
                confirmLabel: '<i class="fas fa-check"></i> Tiếp tục',
                confirmClass: 'dialog-btn-confirm-warning',
                fields: [{
                    id: 'terminationDate',
                    label: 'Ngày kết thúc',
                    type: 'date',
                    defaultValue: new Date().toISOString().split('T')[0],
                    required: true
                }]
            });

            if (dateResult === null) return;

            // Step 3: Reason
            const reasonResult = await showDialog({
                title: 'Lý do kết thúc hợp đồng',
                subtitle: 'Tùy chọn — có thể để trống',
                icon: 'fas fa-comment-dots',
                iconClass: 'icon-info',
                confirmLabel: '<i class="fas fa-save"></i> Xác nhận kết thúc',
                confirmClass: 'dialog-btn-confirm-primary',
                fields: [{
                    id: 'terminationReason',
                    label: 'Lý do (tùy chọn)',
                    type: 'text',
                    placeholder: 'VD: Hết hạn hợp đồng, người thuê tự chuyển đi...'
                }]
            });

            if (reasonResult === null) return;

            showLoading();

            fetch(`/api/room/landlord/${LANDLORD_ID}/end-rental`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    rentalId,
                    terminationDate: typeof dateResult === 'object' ? dateResult.terminationDate : dateResult,
                    terminationReason: typeof reasonResult === 'object' ? reasonResult.terminationReason : reasonResult
                })
            })
            .then(r => r.json())
            .then(result => {
                hideLoading();
                if (result.success) {
                    showAlert('success', result.message);
                    closeRoomDetailModal();
                    loadBuildingDetail(currentBuildingId);
                } else {
                    showAlert('danger', result.message);
                }
            })
            .catch(error => {
                console.error('Error ending rental:', error);
                hideLoading();
                showAlert('danger', 'Lỗi khi kết thúc hợp đồng');
            });
        }

        // =================================================================
        // EDIT ROOM
        // =================================================================
        let currentEditingPropertyId = null;
        let currentEditingRoomIsOccupied = false;
        let currentEditingRoomOccupantsCount = 0;

        function editRoom(propertyId) {
            currentEditingPropertyId = propertyId;

            fetch(`/api/room/${propertyId}/landlord/${LANDLORD_ID}`)
                .then(r => r.json())
                .then(room => {
                    closeRoomDetailModal();

                    const isOccupied = room.status === 'occupied';
                    currentEditingRoomIsOccupied = isOccupied;
                    currentEditingRoomOccupantsCount = room.currentOccupants || 0;

                    const editModal = document.createElement('div');
                    editModal.id = 'editRoomModal';
                    editModal.className = 'modal';
                    editModal.style.display = 'block';

                    // Build status options — nếu đang có người thuê thì disable available & inactive
                    const statusOptions = [
                        { value: 'available', label: 'Trống', disableIfOccupied: true },
                        { value: 'occupied', label: 'Đang thuê', disableIfOccupied: false },
                        { value: 'maintenance', label: 'Bảo trì', disableIfOccupied: false },
                        { value: 'inactive', label: 'Ngừng hoạt động', disableIfOccupied: true }
                    ].map(opt => {
                        const isDisabled = isOccupied && opt.disableIfOccupied;
                        const isSelected = room.status === opt.value;
                        return `<option value="${opt.value}" ${isSelected ? 'selected' : ''} ${isDisabled ? 'disabled' : ''}>
                            ${opt.label}${isDisabled ? ' (không khả dụng khi đang có người thuê)' : ''}
                        </option>`;
                    }).join('');

                    const occupiedWarning = isOccupied ? `
                        <div class="alert alert-warning" style="margin-bottom: 15px;">
                            <i class="fas fa-exclamation-triangle"></i>
                            <strong>Phòng đang có người thuê.</strong>
                            Không thể chuyển sang trạng thái <em>Trống</em> hoặc <em>Ngừng hoạt động</em>.
                            Hãy kết thúc hợp đồng trước.
                        </div>
                    ` : '';

                    const maxOccupantsHint = isOccupied ? `
                        <small class="text-muted">
                            Hiện có <strong>${currentEditingRoomOccupantsCount}</strong> người — số tối đa phải ≥ số hiện tại
                        </small>
                    ` : '';

                    editModal.innerHTML = `
                        <div class="modal-content" style="max-width: 600px;">
                            <div class="modal-header">
                                <h2><i class="fas fa-edit"></i> Sửa thông tin phòng ${room.roomNumber}</h2>
                                <button class="close" onclick="closeEditRoomModal()">&times;</button>
                            </div>
                            <div class="modal-body">
                                ${occupiedWarning}
                                <form id="editRoomForm">
                                    <div class="form-group">
                                        <label>Tên phòng:</label>
                                        <input type="text" id="editRoomTitle" value="${room.title}" class="form-control">
                                    </div>
                                    <div class="form-group">
                                        <label>Mô tả:</label>
                                        <textarea id="editRoomDescription" rows="3" class="form-control">${room.description || ''}</textarea>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Diện tích (m²):</label>
                                                <input type="number" id="editRoomArea" value="${room.area}" step="0.1" min="0" class="form-control">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Số người tối đa:</label>
                                                <input type="number" id="editRoomMaxOccupants" value="${room.maxOccupants}"
                                                    min="${isOccupied ? currentEditingRoomOccupantsCount : 1}" class="form-control">
                                                ${maxOccupantsHint}
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Giá thuê (đ/tháng):</label>
                                                <input type="number" id="editRoomPrice" value="${room.price}" step="100000" min="0" class="form-control">
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label>Tiền cọc (đ):</label>
                                                <input type="number" id="editRoomDeposit" value="${room.deposit}" step="100000" min="0" class="form-control">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <label>Trạng thái:</label>
                                        <select id="editRoomStatus" class="form-control">
                                            ${statusOptions}
                                        </select>
                                    </div>
                                </form>
                            </div>
                            <div class="modal-footer">
                                <button class="btn btn-secondary" onclick="closeEditRoomModal()">Hủy</button>
                                <button class="btn btn-primary" onclick="submitEditRoom()">
                                    <i class="fas fa-save"></i> Lưu thay đổi
                                </button>
                            </div>
                        </div>
                    `;

                    document.body.appendChild(editModal);
                })
                .catch(error => {
                    console.error('Error loading room for edit:', error);
                    showAlert('danger', 'Lỗi khi tải thông tin phòng');
                });
        }

        function closeEditRoomModal() {
            const modal = document.getElementById('editRoomModal');
            if (modal) modal.remove();
            currentEditingPropertyId = null;
            currentEditingRoomIsOccupied = false;
            currentEditingRoomOccupantsCount = 0;
        }

        async function submitEditRoom() {
            if (!currentEditingPropertyId) return;

            const newStatus = document.getElementById('editRoomStatus').value;
            const newMaxOccupants = parseInt(document.getElementById('editRoomMaxOccupants').value);

            // Validate: không được chuyển về trống/ngừng hoạt động khi đang có người thuê
            if (currentEditingRoomIsOccupied && (newStatus === 'available' || newStatus === 'inactive')) {
                showAlert('warning', `Không thể chuyển sang trạng thái "${newStatus === 'available' ? 'Trống' : 'Ngừng hoạt động'}" khi phòng đang có người thuê. Vui lòng kết thúc hợp đồng trước.`);
                return;
            }

            // Validate: số người tối đa phải >= số hiện tại
            if (currentEditingRoomIsOccupied && newMaxOccupants < currentEditingRoomOccupantsCount) {
                showAlert('warning', `Số người tối đa không thể nhỏ hơn số người hiện tại (${currentEditingRoomOccupantsCount} người).`);
                return;
            }

            const data = {
                title: document.getElementById('editRoomTitle').value,
                description: document.getElementById('editRoomDescription').value,
                area: parseFloat(document.getElementById('editRoomArea').value),
                price: parseFloat(document.getElementById('editRoomPrice').value),
                deposit: parseFloat(document.getElementById('editRoomDeposit').value),
                maxOccupants: newMaxOccupants,
                status: newStatus
            };

            if (!data.title || !data.area || !data.price || !data.deposit || !data.maxOccupants) {
                showAlert('warning', 'Vui lòng nhập đầy đủ thông tin');
                return;
            }

            try {
                const response = await fetch(`/api/room/${currentEditingPropertyId}/landlord/${LANDLORD_ID}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    showAlert('success', result.message);
                    closeEditRoomModal();
                    loadBuildingDetail(currentBuildingId);
                } else {
                    showAlert('danger', result.message);
                }
            } catch (error) {
                console.error('Error updating room:', error);
                showAlert('danger', 'Lỗi khi cập nhật phòng');
            }
        }

        // =================================================================
        // DELETE ROOM — uses custom dialog
        // =================================================================
        async function deleteRoom(propertyId) {
            const confirmed = await showDialog({
                title: 'Xóa phòng',
                message: 'Bạn có chắc chắn muốn xóa phòng này? <br><small style="color:#888">Lưu ý: Không thể xóa phòng đang được thuê.</small>',
                icon: 'fas fa-trash-alt',
                iconClass: 'icon-danger',
                confirmLabel: '<i class="fas fa-trash"></i> Xóa phòng',
                confirmClass: 'dialog-btn-confirm-danger',
            });

            if (!confirmed) return;

            showLoading();

            fetch(`/api/room/${propertyId}/landlord/${LANDLORD_ID}`, { method: 'DELETE' })
                .then(r => r.json())
                .then(result => {
                    hideLoading();
                    if (result.success) {
                        showAlert('success', result.message);
                        closeRoomDetailModal();
                        loadBuildingDetail(currentBuildingId);
                    } else {
                        showAlert('danger', result.message);
                    }
                })
                .catch(error => {
                    console.error('Error deleting room:', error);
                    hideLoading();
                    showAlert('danger', 'Lỗi khi xóa phòng');
                });
        }

        // =================================================================
        // ADD ROOM MODAL
        // =================================================================
        function showAddRoomModal() {
            if (!currentBuildingData || !currentBuildingData.floors || currentBuildingData.floors.length === 0) {
                showAlert('warning', 'Vui lòng thiết lập tầng trước khi thêm phòng');
                return;
            }

            const addRoomModal = document.createElement('div');
            addRoomModal.id = 'addRoomModal';
            addRoomModal.className = 'modal';
            addRoomModal.style.display = 'block';

            let floorOptions = '';
            currentBuildingData.floors.forEach(floor => {
                floorOptions += `<option value="${floor.floorId}">${floor.floorName}</option>`;
            });

            const lastFloor = currentBuildingData.floors[currentBuildingData.floors.length - 1];
            const suggestedRoomNumber = lastFloor && lastFloor.rooms.length > 0
                ? generateNextRoomNumber(lastFloor)
                : 'P101';

            addRoomModal.innerHTML = `
                <div class="modal-content" style="max-width: 700px;">
                    <div class="modal-header">
                        <h2><i class="fas fa-plus"></i> Thêm phòng mới</h2>
                        <button class="close" onclick="closeAddRoomModal()">&times;</button>
                    </div>
                    <div class="modal-body">
                        <form id="addRoomForm">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Chọn tầng: <span class="text-danger">*</span></label>
                                        <select id="newRoomFloorId" class="form-control" required onchange="updateRoomNumberSuggestion()">
                                            ${floorOptions}
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Mã phòng: <span class="text-danger">*</span></label>
                                        <input type="text" id="newRoomNumber" value="${suggestedRoomNumber}" required class="form-control" placeholder="VD: P101, P201">
                                        <small class="text-muted">Gợi ý: <span id="roomNumberSuggestion">${suggestedRoomNumber}</span></small>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Tên phòng: <span class="text-danger">*</span></label>
                                <input type="text" id="newRoomTitle" required class="form-control" placeholder="VD: Phòng P101">
                            </div>
                            <div class="form-group">
                                <label>Mô tả:</label>
                                <textarea id="newRoomDescription" rows="3" class="form-control" placeholder="Mô tả về phòng..."></textarea>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Diện tích (m²): <span class="text-danger">*</span></label>
                                        <input type="number" id="newRoomArea" value="25" step="0.1" min="0" required class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Số người tối đa: <span class="text-danger">*</span></label>
                                        <input type="number" id="newRoomMaxOccupants" value="2" min="1" required class="form-control">
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Giá thuê (đ/tháng): <span class="text-danger">*</span></label>
                                        <input type="number" id="newRoomPrice" value="2000000" step="100000" min="0" required class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Tiền cọc (đ): <span class="text-danger">*</span></label>
                                        <input type="number" id="newRoomDeposit" value="2000000" step="100000" min="0" required class="form-control">
                                    </div>
                                </div>
                            </div>
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle"></i>
                                <strong>Lưu ý:</strong> Phòng mới sẽ được tạo với trạng thái "Trống".
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" onclick="closeAddRoomModal()">Hủy</button>
                        <button class="btn btn-primary" onclick="submitAddRoom()">
                            <i class="fas fa-save"></i> Tạo phòng
                        </button>
                    </div>
                </div>
            `;

            document.body.appendChild(addRoomModal);
        }

        function closeAddRoomModal() {
            const modal = document.getElementById('addRoomModal');
            if (modal) modal.remove();
        }

        function generateNextRoomNumber(floor) {
            if (!floor.rooms || floor.rooms.length === 0) return `P${floor.floorNumber}01`;

            const lastRoom = floor.rooms[floor.rooms.length - 1];
            const match = lastRoom.roomNumber.match(/\d+$/);
            if (match) return `P${parseInt(match[0]) + 1}`;
            return `P${floor.floorNumber}01`;
        }

        function updateRoomNumberSuggestion() {
            const floorId = document.getElementById('newRoomFloorId').value;
            const floor = currentBuildingData.floors.find(f => f.floorId == floorId);

            if (floor) {
                const suggestion = generateNextRoomNumber(floor);
                document.getElementById('roomNumberSuggestion').textContent = suggestion;
                document.getElementById('newRoomNumber').value = suggestion;
                document.getElementById('newRoomTitle').value = `Phòng ${suggestion}`;
            }
        }

        async function submitAddRoom() {
            const floorId = document.getElementById('newRoomFloorId').value;
            const roomNumber = document.getElementById('newRoomNumber').value.trim();
            const title = document.getElementById('newRoomTitle').value.trim();
            const description = document.getElementById('newRoomDescription').value.trim();
            const area = parseFloat(document.getElementById('newRoomArea').value);
            const maxOccupants = parseInt(document.getElementById('newRoomMaxOccupants').value);
            const price = parseFloat(document.getElementById('newRoomPrice').value);
            const deposit = parseFloat(document.getElementById('newRoomDeposit').value);

            if (!floorId || !roomNumber || !title || !area || !maxOccupants || !price || !deposit) {
                showAlert('warning', 'Vui lòng nhập đầy đủ thông tin bắt buộc');
                return;
            }

            if (!/^P\d+$/.test(roomNumber)) {
                showAlert('warning', 'Mã phòng phải có dạng P + số (VD: P101, P201)');
                return;
            }

            const data = {
                buildingId: currentBuildingId,
                floorId: parseInt(floorId),
                roomNumber, title, description, area, maxOccupants, price, deposit
            };

            try {
                const response = await fetch(`/api/room/landlord/${LANDLORD_ID}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    showAlert('success', result.message);
                    closeAddRoomModal();
                    loadBuildingDetail(currentBuildingId);
                } else {
                    showAlert('danger', result.message);
                }
            } catch (error) {
                console.error('Error adding room:', error);
                showAlert('danger', 'Lỗi khi tạo phòng');
            }
        }
    </script>
}
