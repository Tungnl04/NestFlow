                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Giá thuê (đ/tháng): <span class="text-danger">*</span></label>
                            <input type="number" id="newBuildingDefaultPrice" value="2000000" step="100000" min="0" required placeholder="VD: 2000000">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Tiền cọc (đ): <span class="text-danger">*</span></label>
