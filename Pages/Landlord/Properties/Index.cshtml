        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeAddOccupantModal()">Hủy</button>
            <button class="btn btn-primary" onclick="submitAddOccupant()">
                <i class="fas fa-save"></i> Lưu
            </button>
        </div>
    </div>
</div>

<!-- Modal: Create Building -->
