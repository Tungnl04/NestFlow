<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NestFlow</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme-modern.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-page="/Home/Index">
                    <span class="nf-brand-blue">Nest</span>flow
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <!-- Visible to all -->
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Home/Index">Trang chủ</a>
                        </li>

                        <!-- Visible to renter & landlord -->
                        <li class="nav-item d-none" id="navFindRoom">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Room/List">Tìm phòng</a>
                        </li>

                        <!-- Landlord only -->
                        <li class="nav-item d-none" id="navLandlordManage">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Landlord/Dashboard">Quản lý trọ</a>
                        </li>

                        <!-- Admin only -->
                        <li class="nav-item d-none" id="navAdminPanel">
                            <a class="nav-link text-dark fw-semibold text-danger" asp-area="" asp-page="/Admin/Dashboard">
                                <i class="fas fa-shield-alt me-1"></i>Quản trị
                            </a>
                        </li>
                    </ul>

                    <!-- Auth Buttons (when not logged in) -->
                    <div class="d-flex gap-2" id="authButtons">
                        <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#loginModal">
                            Đăng nhập
                        </button>
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#registerModal">
                            Đăng ký
                        </button>
                    </div>

                    <!-- Notification Bell (Logged in) -->
                    <div class="d-none me-3" id="notificationBell">
                        <div class="dropdown">
                            <button class="btn btn-light position-relative" type="button" id="notifDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fa-regular fa-bell"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" id="notif-counter">
                                    0
                                    <span class="visually-hidden">unread messages</span>
                                </span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end p-2" aria-labelledby="notifDropdown" style="width: 300px; max-height: 400px; overflow-y: auto;">
                                <li><h6 class="dropdown-header">Thông báo</h6></li>
                                <li><hr class="dropdown-divider"></li>
                                <!-- Notifications will be loaded here -->
                                <li class="text-center text-muted small">Chưa có thông báo mới</li>
                            </ul>
                        </div>
                    </div>

                    <!-- User Dropdown (when logged in) -->
                    <div class="dropdown d-none" id="userDropdown">
                        <button class="btn btn-light dropdown-toggle" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="/images/default-avatar.png" alt="Avatar" class="rounded-circle" width="32" height="32" id="userAvatar">
                            <span id="userName">User</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenuButton">
                            <li>
                                <a class="dropdown-item" href="#" onclick="goToDashboard(); return false;">
                                    <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-page="/Home/Profile">
                                    <i class="fas fa-user me-2"></i>Tài khoản
                                </a>
                            </li>

                            <!-- Renter & Landlord only -->
                            <li class="d-none role-not-admin">
                                <a class="dropdown-item" href="#" onclick="goToBookings(); return false;">
                                    <i class="fas fa-history me-2"></i>Lịch sử đặt phòng
                                </a>
                            </li>
                            <li class="d-none role-not-admin">
                                <a class="dropdown-item" href="#" onclick="goToWallet(); return false;">
                                    <i class="fas fa-wallet me-2"></i>Ví của tôi
                                </a>
                            </li>
                            <li class="d-none role-not-admin">
                                <a class="dropdown-item" asp-page="/Home/Saved">
                                    <i class="fas fa-heart me-2"></i>Tin đã lưu
                                </a>
                            </li>

                            <!-- Admin only -->
                            <li class="d-none role-admin">
                                <a class="dropdown-item" asp-page="/Admin/Users">
                                    <i class="fas fa-users-cog me-2"></i>Quản lý người dùng
                                </a>
                            </li>
                            <li class="d-none role-admin">
                                <a class="dropdown-item" asp-page="/Admin/Posts">
                                    <i class="fas fa-newspaper me-2"></i>Quản lý tin đăng
                                </a>
                            </li>
                            <li class="d-none role-admin">
                                <a class="dropdown-item" asp-page="/Admin/Requests">
                                    <i class="fas fa-bell me-2"></i>Quản lý yêu cầu
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" href="#" onclick="handleLogout()">
                                    <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999">
        <div id="notificationToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header" id="toastHeader">
                <i class="bi me-2" id="toastIcon"></i>
                <strong class="me-auto" id="toastTitle">Thông báo</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body" id="toastMessage">
                Nội dung thông báo
            </div>
        </div>
    </div>

    <footer class="nf-footer">
        <div class="container">
            <div class="row g-4">
                <!-- Về Nestflow -->
                <div class="col-md-3">
                    <h6>Về Nestflow</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="nf-footer-link">Trung tâm trợ giúp</a></li>
                        <li><a href="#" class="nf-footer-link">Feedback khách hàng</a></li>
                        <li><a href="#" class="nf-footer-link">Giới thiệu chủ nhà</a></li>
                        <li><a href="#" class="nf-footer-link">Về chúng tôi</a></li>
                    </ul>
                </div>
                <!-- Khác -->
                <div class="col-md-3">
                    <h6>Khác</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="nf-footer-link">Giới thiệu bạn bè</a></li>
                        <li><a href="#" class="nf-footer-link">Chính sách quyền riêng tư</a></li>
                        <li><a href="#" class="nf-footer-link">Điều khoản và điều kiện</a></li>
                        <li><a href="#" class="nf-footer-link">Thông tin bản quyền</a></li>
                    </ul>
                </div>
                <!-- Pháp lý -->
                <div class="col-md-3">
                    <h6>Pháp lý</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="nf-footer-link">Quyền riêng tư</a></li>
                        <li><a href="#" class="nf-footer-link">Điều khoản</a></li>
                    </ul>
                </div>
                <!-- Branding & Social -->
                <div class="col-md-3">
                    <div class="nf-footer-brand">
                        <div class="nf-footer-logo">
                            <span class="nf-logo-icon">N</span>
                            <span>Nestflow</span>
                        </div>
                        <p class="nf-footer-tagline">Nền tảng cho thuê phòng trọ tại Hòa Lạc</p>
                        <div class="nf-social-icons">
                            <a href="#" class="nf-social-icon"><i class="fab fa-facebook-f"></i></a>
                            <a href="#" class="nf-social-icon"><i class="fab fa-twitter"></i></a>
                            <a href="#" class="nf-social-icon"><i class="fab fa-instagram"></i></a>
                            <a href="#" class="nf-social-icon"><i class="fab fa-youtube"></i></a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="nf-footer-copyright">
                <p class="mb-0">&copy; 2026 Nestflow. Tất cả quyền được bảo lưu.</p>
                <div>
                    <a href="#" class="nf-footer-link me-3">Quyền riêng tư</a>
                    <a href="#" class="nf-footer-link">Điều khoản</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Include Auth Modals -->
    <partial name="_AuthModals" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/notification.js" asp-append-version="true"></script>

    <!-- Auth Script MUST be loaded before page-specific scripts -->
    <script src="~/js/auth.js" asp-append-version="true"></script>
    <script src="~/js/notification-ui.js" asp-append-version="true"></script>

    <script>
        // ─── Role-based nav ───────────────────────────────────────────────────────
        async function applyRoleUI(role) {
            // role: 'admin' | 'landlord' | 'renter' | null

            // Navbar links
            const navFindRoom      = document.getElementById('navFindRoom');
            const navLandlordManage = document.getElementById('navLandlordManage');
            const navAdminPanel    = document.getElementById('navAdminPanel');

            if (role === 'admin') {
                navAdminPanel.classList.remove('d-none');
                // Hide renter/landlord-specific dropdown items
                document.querySelectorAll('.role-not-admin').forEach(el => el.classList.add('d-none'));
                document.querySelectorAll('.role-admin').forEach(el => el.classList.remove('d-none'));

            } else if (role === 'landlord') {
                navFindRoom.classList.remove('d-none');
                navLandlordManage.classList.remove('d-none');
                document.querySelectorAll('.role-not-admin').forEach(el => el.classList.remove('d-none'));

            } else if (role === 'renter') {
                navFindRoom.classList.remove('d-none');
                document.querySelectorAll('.role-not-admin').forEach(el => el.classList.remove('d-none'));

            } else {
                // Guest: show find room in navbar (public)
                navFindRoom.classList.remove('d-none');
            }
        }

        async function loadCurrentUserRole() {
            try {
                const response = await fetch('/api/auth/current-user');
                const data = await response.json();
                if (data.success && data.user) {
                    const role = (data.user.userType || '').toLowerCase(); // 'admin' | 'landlord' | 'renter'
                    await applyRoleUI(role);
                } else {
                    await applyRoleUI(null); // guest
                }
            } catch (e) {
                console.error('Role check failed:', e);
                await applyRoleUI(null);
            }
        }

        // Run on every page load
        document.addEventListener('DOMContentLoaded', loadCurrentUserRole);

        // ─── Logout ───────────────────────────────────────────────────────────────
        async function handleLogout() {
            const result = await window.NestFlowAuth.logout();
            if (result.success) {
                window.location.href = '/';
            } else {
                alert(result.message);
            }
        }

        // ─── Navigation helpers ───────────────────────────────────────────────────
        async function getUserRole() {
            try {
                const res = await fetch('/api/auth/current-user');
                const data = await res.json();
                return data.success && data.user ? (data.user.userType || '').toLowerCase() : null;
            } catch { return null; }
        }

        async function goToWallet() {
            const role = await getUserRole();
            window.location.href = role === 'landlord' ? '/Landlord/Wallet' : '/Home/MyWallet';
        }

        async function goToBookings() {
            const role = await getUserRole();
            window.location.href = role === 'landlord' ? '/Landlord/Bookings' : '/Home/MyBookings';
        }

        async function goToDashboard() {
            const role = await getUserRole();
            if (role === 'admin')    window.location.href = '/Admin/Dashboard';
            else if (role === 'landlord') window.location.href = '/Landlord/Dashboard';
            else                     window.location.href = '/Home/Dashboard';
        }

        // ─── Toast ────────────────────────────────────────────────────────────────
        function showToast(message, type = 'success', title = '') {
            const toast      = document.getElementById('notificationToast');
            const toastHeader = document.getElementById('toastHeader');
            const toastIcon  = document.getElementById('toastIcon');
            const toastTitle = document.getElementById('toastTitle');
            const toastMessage = document.getElementById('toastMessage');

            toastMessage.textContent = message;
            toastHeader.className = 'toast-header';
            toastIcon.className   = 'bi me-2';

            const styles = {
                success: { bg: 'bg-success text-white', icon: 'bi-check-circle-fill',         label: 'Thành công' },
                error:   { bg: 'bg-danger text-white',  icon: 'bi-x-circle-fill',              label: 'Lỗi'       },
                warning: { bg: 'bg-warning text-dark',  icon: 'bi-exclamation-triangle-fill',  label: 'Cảnh báo'  },
                info:    { bg: 'bg-info text-white',    icon: 'bi-info-circle-fill',           label: 'Thông tin' },
            };
            const s = styles[type] || styles.info;
            s.bg.split(' ').forEach(c => toastHeader.classList.add(c));
            toastIcon.classList.add(s.icon);
            toastTitle.textContent = title || s.label;

            new bootstrap.Toast(toast, { autohide: true, delay: 3000 }).show();
        }
    </script>

    <partial name="_AIChatWidget" />
    <script src="~/js/ai-chat.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>